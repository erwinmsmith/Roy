{
  "name": "roy",
  "version": "0.1.0",
  "description": "Observable, budget-aware Theory-of-Mind multi-agent runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/core/runtime/index.d.ts",
      "import": "./dist/core/runtime/index.js"
    },
    "./team": {
      "types": "./dist/core/team/index.d.ts",
      "import": "./dist/core/team/index.js"
    },
    "./tom": {
      "types": "./dist/core/tom/index.d.ts",
      "import": "./dist/core/tom/index.js"
    },
    "./communication": {
      "types": "./dist/core/communication/index.d.ts",
      "import": "./dist/core/communication/index.js"
    },
    "./delegation": {
      "types": "./dist/core/delegation/index.d.ts",
      "import": "./dist/core/delegation/index.js"
    },
    "./budget": {
      "types": "./dist/core/budget/index.d.ts",
      "import": "./dist/core/budget/index.js"
    },
    "./evolution": {
      "types": "./dist/core/evolution/index.d.ts",
      "import": "./dist/core/evolution/index.js"
    },
    "./lifecycle": {
      "types": "./dist/core/lifecycle/index.d.ts",
      "import": "./dist/core/lifecycle/index.js"
    },
    "./llm": {
      "types": "./dist/core/llm/index.d.ts",
      "import": "./dist/core/llm/index.js"
    },
    "./queue": {
      "types": "./dist/core/queue/index.d.ts",
      "import": "./dist/core/queue/index.js"
    },
    "./memory": {
      "types": "./dist/core/memory/index.d.ts",
      "import": "./dist/core/memory/index.js"
    }
  },
  "bin": {
    "roy": "dist/cli/Roy.js",
    "roy-server": "dist/server/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    ".env.example",
    "roy.config.example.yaml"
  ],
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "tsx src/server/index.ts",
    "dev:cli": "tsx src/cli/Roy.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "start:cli": "node dist/cli/Roy.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "check": "tsc --noEmit && eslint src --ext .ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "cheerio": "^1.1.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "js-yaml": "^4.3.0",
    "openai": "^4.82.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.6",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "body-parser": "1.20.6",
    "brace-expansion": "5.0.7",
    "esbuild": "0.28.1",
    "form-data": "4.0.6",
    "vite": "8.1.5",
    "ws": "8.21.1"
  }
}

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# also support other providers by openai
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Optional production web search provider. Without this key, Roy falls back to
# Bing RSS, whose result quality can vary by network and locale.
BRAVE_SEARCH_API_KEY=

# Default Model
# DeepSeek models: deepseek-v4-flash, deepseek-v4-pro
DEFAULT_MODEL=deepseek-v4-flash

# Server
PORT=3000

# Logging
LOG_LEVEL=info
